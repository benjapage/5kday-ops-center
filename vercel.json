{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/google-drive-sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/manychat-check",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/meta-sync?days=1",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/utmify/sync?days=1",
      "schedule": "0 10 * * *"
    }
  ]
}
