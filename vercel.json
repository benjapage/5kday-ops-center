{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/external?_path=chat" },
    { "source": "/api/dolar-blue", "destination": "/api/external?_path=internal/dolar-blue" },
    { "source": "/api/external/:path*", "destination": "/api/external?_path=:path*" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/google-drive-sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/manychat-check",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/utmify?action=sync&days=1",
      "schedule": "0 10 * * *"
    }
  ]
}
